#! /usr/local/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/local/lib/ivl/system.vpi";
:vpi_module "/usr/local/lib/ivl/vhdl_sys.vpi";
:vpi_module "/usr/local/lib/ivl/vhdl_textio.vpi";
:vpi_module "/usr/local/lib/ivl/v2005_math.vpi";
:vpi_module "/usr/local/lib/ivl/va_math.vpi";
:vpi_module "/usr/local/lib/ivl/v2009.vpi";
S_0x2e809810 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x2e8099a0 .scope module, "tb_sync_ram" "tb_sync_ram" 3 3;
 .timescale -9 -12;
v0x2e81ffa0_0 .var "addr", 3 0;
v0x2e820080_0 .var "clk", 0 0;
v0x2e820150_0 .var "din", 7 0;
v0x2e820250_0 .net "dout", 7 0, v0x2e81fc50_0;  1 drivers
v0x2e820320_0 .var "we", 0 0;
S_0x2e7e3580 .scope module, "uut" "sync_ram" 3 12, 4 1 0, S_0x2e8099a0;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "we";
    .port_info 2 /INPUT 4 "addr";
    .port_info 3 /INPUT 8 "din";
    .port_info 4 /OUTPUT 8 "dout";
P_0x2e7e3760 .param/l "ADDR_WIDTH" 0 4 3, +C4<00000000000000000000000000000100>;
P_0x2e7e37a0 .param/l "DATA_WIDTH" 0 4 2, +C4<00000000000000000000000000001000>;
v0x2e7d22e0_0 .net "addr", 3 0, v0x2e81ffa0_0;  1 drivers
v0x2e81faa0_0 .net "clk", 0 0, v0x2e820080_0;  1 drivers
v0x2e81fb60_0 .net "din", 7 0, v0x2e820150_0;  1 drivers
v0x2e81fc50_0 .var "dout", 7 0;
v0x2e81fd30 .array "mem", 15 0, 7 0;
v0x2e81fe40_0 .net "we", 0 0, v0x2e820320_0;  1 drivers
E_0x2e80a610 .event posedge, v0x2e81faa0_0;
    .scope S_0x2e7e3580;
T_0 ;
    %wait E_0x2e80a610;
    %load/vec4 v0x2e81fe40_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %load/vec4 v0x2e81fb60_0;
    %load/vec4 v0x2e7d22e0_0;
    %pad/u 6;
    %ix/vec4 3;
    %ix/load 4, 0, 0; Constant delay
    %assign/vec4/a/d v0x2e81fd30, 0, 4;
T_0.0 ;
    %load/vec4 v0x2e7d22e0_0;
    %pad/u 6;
    %ix/vec4 4;
    %load/vec4a v0x2e81fd30, 4;
    %assign/vec4 v0x2e81fc50_0, 0;
    %jmp T_0;
    .thread T_0;
    .scope S_0x2e8099a0;
T_1 ;
    %delay 5000, 0;
    %load/vec4 v0x2e820080_0;
    %inv;
    %store/vec4 v0x2e820080_0, 0, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_0x2e8099a0;
T_2 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x2e820080_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x2e820320_0, 0, 1;
    %pushi/vec4 0, 0, 4;
    %store/vec4 v0x2e81ffa0_0, 0, 4;
    %pushi/vec4 0, 0, 8;
    %store/vec4 v0x2e820150_0, 0, 8;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x2e820320_0, 0, 1;
    %pushi/vec4 0, 0, 4;
    %store/vec4 v0x2e81ffa0_0, 0, 4;
    %pushi/vec4 161, 0, 8;
    %store/vec4 v0x2e820150_0, 0, 8;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 4;
    %store/vec4 v0x2e81ffa0_0, 0, 4;
    %pushi/vec4 178, 0, 8;
    %store/vec4 v0x2e820150_0, 0, 8;
    %delay 10000, 0;
    %pushi/vec4 2, 0, 4;
    %store/vec4 v0x2e81ffa0_0, 0, 4;
    %pushi/vec4 195, 0, 8;
    %store/vec4 v0x2e820150_0, 0, 8;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x2e820320_0, 0, 1;
    %delay 10000, 0;
    %pushi/vec4 0, 0, 4;
    %store/vec4 v0x2e81ffa0_0, 0, 4;
    %delay 10000, 0;
    %pushi/vec4 1, 0, 4;
    %store/vec4 v0x2e81ffa0_0, 0, 4;
    %delay 10000, 0;
    %pushi/vec4 2, 0, 4;
    %store/vec4 v0x2e81ffa0_0, 0, 4;
    %delay 20000, 0;
    %vpi_call/w 3 42 "$finish" {0 0 0};
    %end;
    .thread T_2;
    .scope S_0x2e8099a0;
T_3 ;
    %vpi_call/w 3 47 "$monitor", "Time=%0t | WE=%b | Addr=%d | Din=%h | Dout=%h", $time, v0x2e820320_0, v0x2e81ffa0_0, v0x2e820150_0, v0x2e820250_0 {0 0 0};
    %end;
    .thread T_3;
